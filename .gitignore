# Go
/bin/
*.test
*.out
# compiled runner binary (do not commit)
/runners/go/go
/runners/go/runner
# Rust build artifacts
/runners/rust/target/
# local cargo registry-proxy config (environment-specific)
/runners/rust/.cargo/
# Java build artifacts
/runners/java/build/
/runners/java/.gradle/
# local gradle maven-proxy config (environment-specific)
/runners/java/gradle.properties
# runner scratch warehouses
/tmp/
warehouse/
# generated reports (report.json is regenerated by the orchestrator in CI and
# served from the deploy; committing it is redundant)
/report/
/site/report.json
# orchestrator python cache
__pycache__/
*.pyc
# CI scratch (downloaded runner binaries / staged java image)
/dist/
# built orchestrator binary
/orch
/orchestrator/orch
# Hadoop checksum sidecars (write-tool noise; never part of a minted fixture)
*.crc
