      "yaml": "# Spec — v2 two appends + time-travel, NO delete. Authored-golden.\n#\n# The universal-write fixture: it uses only create + append + scan + time-travel,\n# which every implementation supports. This is the cross-implementation baseline\n# — iceberg-go AND iceberg-rust both run it fully green, so a divergence here is a\n# real interop bug, not a feature gap. (The sibling v2_append_posdelete_timetravel\n# adds a merge-on-read delete, which iceberg-rust cannot write yet -\u003e exit 4.)\n#\n# Pins: snapshot ordinals across two commits (0, 1), the append operation, live\n# row multiset after each append, and a time-travel read of the first snapshot.\n\nheader:\n  id: v2_append_timetravel\n  format-version: 2\n  spec-anchor: \"table-spec#snapshots\"\n  table-uuid: \"7b3e1a02-9c4d-4f18-8a2b-6e5f0d1c2b3a\"\n  seeds:\n    snapshot-id: sequential\n    commit-ts: \"2026-01-01T00:00:00Z\"\n    file-paths: templated\n  schema:\n    fields:\n      - { id: 1, name: id,       type: long,   required: true }\n      - { id: 2, name: category, type: string }\n\nentries:\n  - op: append\n    rows:\n      - { __rowkey: r1, id: !long 1, category: !string \"a\" }\n      - { __rowkey: r2, id: !long 2, category: !string \"b\" }\n    expect:\n      snapshot: { operation: append }\n\n  - op: observe\n    at: latest\n    bind: after-first\n    expect:\n      scan:\n        rows:\n          - { id: 1, category: a }\n          - { id: 2, category: b }\n\n  - op: append\n    rows:\n      - { __rowkey: r3, id: !long 3, category: !string \"a\" }\n    expect:\n      snapshot: { operation: append }\n\n  - op: observe\n    at: latest\n    bind: after-second\n    expect:\n      scan:\n        rows:\n          - { id: 1, category: a }\n          - { id: 2, category: b }\n          - { id: 3, category: a }\n\n  # time-travel: the first snapshot still reads only the first two rows\n  - op: observe\n    at: after-first\n    expect:\n      scan:\n        rows:\n          - { id: 1, category: a }\n          - { id: 2, category: b }\n"
    },
