      "yaml": "# Spec 1 — v2 append + merge-on-read POSITION delete + time-travel.\n# Authored-golden mode (expect present). Green on iceberg-go: MoR delete writes\n# position deletes today, which is exactly what this pins.\n#\n# NOTE: this is the position-delete case, NOT equality. Equality delete is a\n# declared gap for iceberg-go (see supports.yaml) — a separate spec would exit 4.\n\nheader:\n  id: v2_append_posdelete_timetravel\n  format-version: 2\n  spec-anchor: \"table-spec#row-level-deletes\"\n  table-uuid: \"9c12d441-03fe-4693-9a96-a0705ddf69c1\"\n  seeds:\n    snapshot-id: sequential\n    commit-ts: \"2026-01-01T00:00:00Z\"\n    file-paths: templated\n  schema:\n    fields:\n      - { id: 1, name: id,       type: long,   required: true }\n      - { id: 2, name: category, type: string }\n\nentries:\n  - op: append\n    rows:\n      - { __rowkey: r1, id: !long 1, category: !string \"a\" }\n      - { __rowkey: r2, id: !long 2, category: !string \"b\" }\n      - { __rowkey: r3, id: !long 3, category: !string \"a\" }\n    expect:\n      snapshot: { operation: append }\n\n  - op: observe\n    at: latest\n    bind: after-append\n    expect:\n      scan:\n        rows:\n          - { id: 1, category: a }\n          - { id: 2, category: b }\n          - { id: 3, category: a }\n\n  - op: delete\n    strategy: merge-on-read\n    kind: position\n    predicate: { type: eq, term: id, value: !long 2 }\n    expect:\n      snapshot: { operation: delete }\n      delete-file: { content: 1 }          # positional (not a deletion vector, not equality)\n\n  # rule: mutations assert snapshot facts; observes assert row-state.\n  - op: observe\n    at: latest\n    bind: after-delete\n    expect:\n      scan:\n        rows:\n          - { id: 1, category: a }\n          - { id: 3, category: a }\n\n  # time-travel: the pre-delete snapshot still reads all three rows\n  - op: observe\n    at: after-append\n    expect:\n      scan:\n        rows:\n          - { id: 1, category: a }\n          - { id: 2, category: b }\n          - { id: 3, category: a }\n"
