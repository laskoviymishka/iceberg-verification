      "yaml": "# Spec 3 — v3 schema evolution + default values + time-travel across the change.\n# Authored-golden. Green on iceberg-go: UpdateSchema (promote-type, add-column\n# with initial-default/write-default).\n#\n# Row lineage (_row_id / next-row-id) is expressed logically (__rowkey -\u003e row-id)\n# rather than by raw reserved field-id; VERIFY the exact reserved ids against the\n# current v3 spec before blessing the golden.\n\nheader:\n  id: v3_schema_evolution_defaults\n  format-version: 3\n  spec-anchor: \"table-spec#schema-evolution\"\n  table-uuid: \"aa11bb22-cc33-dd44-ee55-ff6677889900\"\n  seeds:\n    snapshot-id: sequential\n    commit-ts: \"2026-01-01T00:00:00Z\"\n    file-paths: templated\n  schema:\n    fields:\n      - { id: 1, name: id,   type: int, required: true }\n      - { id: 2, name: name, type: string }\n\nentries:\n  - op: append\n    rows:\n      - { __rowkey: r1, id: !int 1, name: !string \"ann\" }\n      - { __rowkey: r2, id: !int 2, name: !string \"bob\" }\n\n  - op: observe\n    at: latest\n    bind: v1\n\n  - op: evolve-schema\n    changes:\n      - kind: promote-type\n        field-id: 1\n        to: long\n      - kind: add-column\n        field:\n          id: 3\n          name: score\n          type: long\n          initial-default: !long 0     # existing rows read as 0\n          write-default: !long 0       # new rows omitting score get 0\n\n  - op: append\n    rows:\n      - { __rowkey: r3, id: !long 3, name: !string \"cid\" }   # score omitted -\u003e write-default\n\n  - op: observe\n    at: latest\n    expect:\n      scan:\n        rows:\n          - { id: 1, name: ann, score: 0 }   # initial-default backfills existing rows\n          - { id: 2, name: bob, score: 0 }\n          - { id: 3, name: cid, score: 0 }   # write-default fills the omitted column\n      physical:\n        metadata.next-row-id: \"\u003e= 3\"\n        row-lineage: { r1: 0, r2: 1, r3: 2 }\n\n  # pre-evolution snapshot reads the old schema and rows only\n  - op: observe\n    at: v1\n    expect:\n      scan:\n        rows:\n          - { id: 1, name: ann }\n          - { id: 2, name: bob }\n"
